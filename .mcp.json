{
  "mcpServers": {
    "MCP_DOCKER": {
      "command": "${ProgramFiles}/Docker/cli-plugins/docker-mcp.exe",
      "args": [
        "gateway",
        "run"
      ],
      "env": {
        "LOCALAPPDATA": "${LOCALAPPDATA}",
        "ProgramData": "${ProgramData}",
        "ProgramFiles": "${ProgramFiles}"
      }
    }
  }
}
