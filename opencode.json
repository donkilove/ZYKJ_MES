{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "sequential_thinking": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "context7": {
      "type": "remote",
      "url": "https://mcp.context7.com/mcp",
      "enabled": true,
      "timeout": 120000
    },
    "serena": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "uv",
        "tool",
        "run",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "playwright": {
      "type": "local",
      "command": [
        "npx",
        "-y",
        "@playwright/mcp@latest"
      ],
      "enabled": true,
      "timeout": 120000
    },
    "postgres": {
      "type": "local",
      "command": [
        "python",
        "tools/project_toolkit.py",
        "postgres-mcp"
      ],
      "enabled": true,
      "timeout": 120000
    }
  }
}
