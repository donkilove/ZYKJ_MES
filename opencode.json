{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "serena": {
      "type": "local",
      "command": [
        "python",
        "-m",
        "uv",
        "tool",
        "run",
        "--from",
        "git+https://github.com/oraios/serena",
        "serena",
        "start-mcp-server",
        "--context",
        "ide-assistant"
      ],
      "enabled": true,
      "timeout": 60000
    },
    "postgres": {
      "type": "local",
      "command": ["python", "tools/project_toolkit.py", "postgres-mcp"],
      "enabled": true,
      "timeout": 10000
    }
  }
}
