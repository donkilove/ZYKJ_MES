APP_NAME="ZYKJ MES API"
APP_ENV=dev
APP_HOST=0.0.0.0
APP_PORT=8000
API_V1_PREFIX=/api/v1

DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=mes_db
DB_USER=mes_user
DB_PASSWORD=mes_password
DB_POOL_SIZE=6
DB_MAX_OVERFLOW=4
DB_POOL_TIMEOUT_SECONDS=5
DB_POOL_RECYCLE_SECONDS=1800
WORKER_DB_POOL_SIZE=2
WORKER_DB_MAX_OVERFLOW=2
WORKER_DB_POOL_TIMEOUT_SECONDS=5
WORKER_DB_POOL_RECYCLE_SECONDS=1800
GUNICORN_MAX_REQUESTS=0
GUNICORN_MAX_REQUESTS_JITTER=0

REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0
REDIS_PASSWORD=
REDIS_SSL=false
REDIS_SOCKET_TIMEOUT_SECONDS=0.2
REDIS_CONNECT_TIMEOUT_SECONDS=0.2
AUTHZ_PERMISSION_CACHE_REDIS_ENABLED=true
AUTHZ_PERMISSION_CACHE_PREFIX=authz:permission:v1
AUTHZ_PERMISSION_CACHE_TTL_SECONDS=60

BOOTSTRAP_ON_STARTUP=true
WEB_RUN_BOOTSTRAP=true
WEB_RUN_BACKGROUND_LOOPS=true
WORKER_RUN_BOOTSTRAP=true
WORKER_RUN_BACKGROUND_LOOPS=true
DB_BOOTSTRAP_HOST=127.0.0.1
DB_BOOTSTRAP_PORT=5432
DB_BOOTSTRAP_USER=postgres
DB_BOOTSTRAP_PASSWORD=
DB_BOOTSTRAP_MAINTENANCE_DB=postgres
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=Admin@123456
ONLINE_STATUS_TTL_SECONDS=90
SESSION_TOUCH_MIN_INTERVAL_SECONDS=30
MAINTENANCE_AUTO_GENERATE_ENABLED=true
MAINTENANCE_AUTO_GENERATE_TIME=00:05
MAINTENANCE_AUTO_GENERATE_TIMEZONE=Asia/Shanghai
PRODUCTION_DEFAULT_VERIFICATION_CODE=123456

JWT_SECRET_KEY=replace_with_a_strong_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
