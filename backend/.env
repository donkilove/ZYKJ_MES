DB_BOOTSTRAP_PASSWORD=123456
DB_BOOTSTRAP_MAINTENANCE_DB=postgres
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=admin@123456
PRODUCTION_DEFAULT_VERIFICATION_CODE=FA20260419

JWT_SECRET_KEY=zykj-mes-dev-secret-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=120
