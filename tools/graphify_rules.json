      { "pattern": "alembic/", "tag": "migrations" },
      { "pattern": "backend/app/models/", "tag": "backend-core" },
      { "pattern": "backend/app/services/", "tag": "backend-core" },
      { "pattern": "backend/app/api/", "tag": "backend-core" },
      { "pattern": "frontend/lib/", "tag": "frontend-core" },
      { "pattern": "desktop_tests/", "tag": "tests" },
      { "pattern": "docker/", "tag": "infrastructure" },
      { "pattern": "docs/", "tag": "documentation" },
      { "pattern": "tools/", "tag": "infrastructure" }
    ]
  },

  "community_naming": {
    "description": "社区命名规则",
    "template": "{primary_domain} - {primary_entity}",
    "fallback": "未分类模块 {community_id}",
    "domain_labels": {
      "authz": "用户权限",
      "product": "产品管理",
      "craft": "工艺管理",
      "production": "生产执行",
      "quality": "质量管理",
      "equipment": "设备管理",
      "message": "消息推送",
      "plugin": "插件系统",
      "frontend-core": "前端基础设施",
      "backend-core": "后端基础设施",
      "tests": "测试模块",
      "migrations": "数据库迁移",
      "infrastructure": "基础设施",
      "documentation": "文档资料"
    }
  },

  "navigation_rules": {
    "entrypoints": {
      "backend": ["backend/app/main.py", "backend/app/worker_main.py",
                  "backend/app/api/v1/api.py", "backend/app/bootstrap/"],
      "frontend": ["frontend/lib/main.dart", "frontend/lib/core/app.dart",
                   "frontend/lib/core/router.dart"],
      "scripts": ["start_backend.py", "start_frontend.py", "tools/"],
      "tests": ["tests/", "frontend/integration_test/", "desktop_tests/"]
    },
    "contract_objects": [
      "EquipmentLedgerItem", "MaintenanceItemEntry", "ProductionOrder",
      "Role", "Product", "Process", "QualityInspection", "AppSession", "User"
    ],
    "contract_supplements": {
      "EquipmentLedgerItem": {
        "schemas": ["backend/app/schemas/equipment.py"],
        "frontend_services": [
          "frontend/lib/features/equipment/services/equipment_service.dart"
        ],
        "endpoints": [
          "backend/app/api/v1/endpoints/equipment.py"
        ],
        "frontend_models": [
          "frontend/lib/features/equipment/models/equipment_models.dart"
        ],
        "frontend_pages": [
          "frontend/lib/features/equipment/presentation/equipment_ledger_page.dart",
          "frontend/lib/features/equipment/presentation/equipment_page.dart"
        ],
        "tests": [
          "frontend/test/widgets/equipment_module_pages_test.dart",
          "frontend/test/services/equipment_service_test.dart",
          "frontend/integration_test/login_flow_test.dart"
        ]
      },
      "MaintenanceItemEntry": {
        "schemas": ["backend/app/schemas/equipment.py"],
        "frontend_services": [
          "frontend/lib/features/equipment/services/equipment_service.dart"
        ],
        "endpoints": [
          "backend/app/api/v1/endpoints/equipment.py"
        ],
        "frontend_models": [
          "frontend/lib/features/equipment/models/equipment_models.dart"
        ],
        "frontend_pages": [
          "frontend/lib/features/equipment/presentation/maintenance_item_page.dart",
          "frontend/lib/features/equipment/presentation/maintenance_plan_page.dart"
        ],
        "tests": [
          "frontend/test/widgets/equipment_module_pages_test.dart",
          "frontend/test/models/equipment_models_test.dart",
          "frontend/test/services/equipment_service_test.dart"
        ]
      },
      "AppSession": {
