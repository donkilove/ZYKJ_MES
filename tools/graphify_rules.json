          "frontend/test/widgets/main_shell_page_test.dart",
          "frontend/integration_test/login_flow_test.dart"
        ]
      }
    },
    "impact_objects": [
      "ProductionOrder", "Equipment", "Role", "AppSession", "Product",
      "Process", "QualityInspection", "User"
