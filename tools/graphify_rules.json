{
  "version": "1.0.0",
  "description": "Graphify 图谱治理规则配置 - 泛节点、文本噪音、域标签、社区命名与视图规则",

  "noise_rules": {
    "generic_nodes": {
      "description": "泛节点列表，按处理方式分类",
      "drop_from_curated": {
        "description": "完全从治理后图谱删除的节点",
        "labels": ["build", "main", "initState", "dispose", "didChangeDependencies",
                   "createState", "Widget", "BuildContext", "BuildOwner", "Element",
                   "Diagnosticable", "DiagnosticableTree", "Key", "StatefulWidget",
                   "StatelessWidget", "GlobalKey", "LocalKey", "ValueKey", "ObjectKey",
                   "UniqueKey", "InheritedWidget", "RenderObjectWidget",
                   "SingleChildRenderObjectWidget", "MultiChildRenderObjectWidget",
                   "NotificationListener", "ValueListenableBuilder", "AnimatedWidget",
                   "FormField", "InputDecoration", "TextEditingController", "FocusNode",
                   "ScrollController", "ScrollPhysics", "PageController", "TabController",
                   "AnimationController", "Curve", "Tween", "TickerProvider",
                   "Route", "Navigator", "ModalRoute", "PageRoute", "PopupRoute",
                   "LocalizationsDelegate", "WidgetsApp", "WidgetInspector",
                   "SizedBox", "Container", "Column", "Row", "Flex", "Wrap", "Stack",
                   "ListView", "GridView", "SingleChildScrollView", "CustomScrollView",
                   "SliverList", "SliverGrid", "SliverToBoxAdapter",
                   "Center", "Align", "Padding", "Expanded", "Flexible",
                   "SafeArea", "MediaQuery", "Theme", "TextTheme", "IconTheme",
                   "MaterialApp", "CupertinoApp", "Scaffold", "AppBar", "Drawer",
                   "BottomNavigationBar", "TabBar", "TabBarView",
                   "TextButton", "ElevatedButton", "OutlinedButton", "IconButton",
                   "FloatingActionButton", "PopupMenuButton", "DropdownButton",
                   "Checkbox", "Radio", "Switch", "Slider", "TextField",
                   "ListViewBuilder", "GridViewBuilder",
                   "AsyncSnapshot", "StreamBuilder", "FutureBuilder",
                   "CircularProgressIndicator", "LinearProgressIndicator",
                   "SnackBar", "Dialog", "AlertDialog", "SimpleDialog",
                   "BottomSheet", "DraggableScrollableSheet",
                   "Form", "FormState", "GlobalKey_FormState",
                   "GestureDetector", "InkWell", "Listener",
                   "Overlay", "OverlayEntry", "OverlayState",
                   "Positioned", "Transform", "Opacity", "ClipRRect", "DecoratedBox",
                   "ValueNotifier", "ChangeNotifier", "ChangeNotifierProvider",
                   "Provider", "MultiProvider", "Consumer", "Selector",
                   "StateNotifier", "StateNotifierProvider", "StateProvider",
                   "set", "print", "debugPrint", "assert",
                   "ValueError", "TypeError", "KeyError", "AttributeError",
                   "IndexError", "RuntimeError", "NotImplementedError",
                   "Exception", "BaseException", "OSError", "IOError",
                   "BaseModel", "Field", "model_validator", "field_validator",
                   "ConfigDict", "model_config", "ValidationError", "ValidationInfo"]
      },
      "hide_from_rank": {
        "description": "保留在图但不出现在God Nodes/Top N/社区摘要中",
        "labels": ["__init__", "__init__", "mount", "pump", "buildScope",
                   "performRebuild", "scheduleBuildFor", "markNeedsBuild",
                   "activate", "deactivate", "reassemble", "didUpdateWidget",
                   "fromMap", "toMap", "copyWith", "toJson", "fromJson",
                   "notifyListeners", "addListener", "removeListener",
                   "toString", "hashCode", "noSuchMethod", "runtimeType",
                   "operator ==", "didChangeDependencies", "debugFillProperties",
                   "debugDescribeChildren", "createElement", "updateRenderObject",
                   "createRenderObject", "describeSemanticsConfiguration",
                   "hasSize", "constraints", "createState", "paint", "layout",
                   "hitTest", "applyPaintTransform", "computeMinIntrinsicWidth",
                   "computeMaxIntrinsicWidth", "computeMinIntrinsicHeight",
                   "computeMaxIntrinsicHeight", "computeDryLayout",
                   "setState", "context", "widget", "ref", "mounted"]
      },
      "downweight": {
        "description": "降低中心性和社区命名权重",
        "labels": ["Color", "Colors", "FontWeight", "FontSize", "TextStyle",
                   "EdgeInsets", "BoxDecoration", "BorderRadius", "BoxShadow",
                   "Border", "BorderSide", "Gradient", "LinearGradient",
                   "Icon", "IconData", "Image", "AssetImage", "NetworkImage",
                   "Text", "RichText", "TextSpan", "DefaultTextStyle",
                   "Padding", "Margin", "Size", "Offset", "Rect", "Alignment",
                   "MainAxisAlignment", "CrossAxisAlignment", "MainAxisSize",
                   "DateTime", "Duration", "Timer", "Stopwatch", "Stopwatch",
                   "StringBuffer", "Logger", "LogRecord", "LogFilter",
                   "Runner", "TestGroup", "Test", "setUp", "tearDown",
                   "setUpAll", "tearDownAll", "testWidgets", "group",
                   "pumpWidget", "pump", "expect", "findsOneWidget",
                   "findsNothing", "findsWidgets", "findsNWidgets",
                   "findsAtLeastNWidgets", "matchesGoldenFile",
                   "Mock", "Fake", "Stub", "Spy", "Dummy",
                   "TestWidgetsFlutterBinding", "AutomatedTestWidgetsFlutterBinding"]
      }
    },
    "text_noise": {
      "description": "文本型噪音匹配模式",
      "patterns": [
        { "type": "regex", "field": "label", "pattern": "^Revision ID:", "action": "drop_from_curated", "reason": "Alembic revision标题" },
        { "type": "regex", "field": "label", "pattern": "^Create Date:", "action": "drop_from_curated", "reason": "Alembic revision标题" },
        { "type": "regex", "field": "label", "pattern": "Run migrations in '(offline|online)' mode", "action": "drop_from_curated", "reason": "Alembic迁移说明" },
        { "type": "regex", "field": "label", "pattern": "^Revises:", "action": "drop_from_curated", "reason": "Alembic revision标记" },
        { "type": "length", "field": "label", "min_length": 80, "action": "hide_from_rank", "reason": "过长标签（docstring片段）" },
        { "type": "regex", "field": "label", "pattern": "^(\\s*#|\\s*\"\"\"|\\s*''').*", "action": "hide_from_rank", "reason": "注释/文档字符串片段" },
        { "type": "regex", "field": "label", "pattern": "^(TODO|FIXME|HACK|XXX|NOTE|WARNING|DEPRECATED):", "action": "hide_from_rank", "reason": "代码注释标记" }
      ]
    },
    "path_noise": {
      "description": "路径型噪音匹配模式",
      "patterns": [
        { "pattern": "alembic/", "action": "hide_from_rank", "reason": "迁移脚本节点" },
        { "pattern": "__pycache__/", "action": "drop_from_curated", "reason": "Python缓存" },
        { "pattern": ".dart_tool/", "action": "drop_from_curated", "reason": "Dart工具缓存" },
        { "pattern": "/build/", "action": "drop_from_curated", "reason": "构建产物" },
        { "pattern": "/.pub-cache/", "action": "drop_from_curated", "reason": "Dart包缓存" },
        { "pattern": "/windows/flutter/", "action": "hide_from_rank", "reason": "Flutter平台生成代码" }
      ]
    },
    "framework_imports": {
      "description": "框架导入节点，允许存在但不主导报告",
      "patterns": [
        { "pattern": "package:flutter/", "tag": "flutter_sdk" },
        { "pattern": "package:flutter_test/", "tag": "flutter_test" },
        { "pattern": "dart:", "tag": "dart_sdk" },
        { "pattern": "sqlalchemy", "tag": "sqlalchemy" },
        { "pattern": "fastapi", "tag": "fastapi" },
        { "pattern": "pydantic", "tag": "pydantic" }
      ]
    }
  },

  "domain_rules": {
    "description": "按路径规则给节点打领域标签",
    "mappings": [
      { "pattern": "backend/app/models/(user|role|permission|authz)", "tag": "authz" },
      { "pattern": "backend/app/models/production", "tag": "production" },
      { "pattern": "backend/app/models/product", "tag": "product" },
      { "pattern": "backend/app/models/process", "tag": "craft" },
      { "pattern": "backend/app/models/craft", "tag": "craft" },
      { "pattern": "backend/app/models/production", "tag": "production" },
      { "pattern": "backend/app/models/quality", "tag": "quality" },
      { "pattern": "backend/app/models/equipment", "tag": "equipment" },
      { "pattern": "backend/app/models/maintenance", "tag": "equipment" },
      { "pattern": "backend/app/models/(message|notification)", "tag": "message" },
      { "pattern": "backend/app/services/(user|role|permission|authz)", "tag": "authz" },
      { "pattern": "backend/app/services/production", "tag": "production" },
      { "pattern": "backend/app/services/product", "tag": "product" },
      { "pattern": "backend/app/services/process", "tag": "craft" },
      { "pattern": "backend/app/services/craft", "tag": "craft" },
      { "pattern": "backend/app/services/production", "tag": "production" },
      { "pattern": "backend/app/services/quality", "tag": "quality" },
      { "pattern": "backend/app/services/equipment", "tag": "equipment" },
      { "pattern": "backend/app/services/maintenance", "tag": "equipment" },
      { "pattern": "backend/app/services/(message|notification|websocket)", "tag": "message" },
      { "pattern": "backend/app/api/v1/endpoints/(user|role|permission|authz)", "tag": "authz" },
      { "pattern": "backend/app/api/v1/endpoints/production", "tag": "production" },
      { "pattern": "backend/app/api/v1/endpoints/product", "tag": "product" },
      { "pattern": "backend/app/api/v1/endpoints/process", "tag": "craft" },
      { "pattern": "backend/app/api/v1/endpoints/craft", "tag": "craft" },
      { "pattern": "backend/app/api/v1/endpoints/production", "tag": "production" },
      { "pattern": "backend/app/api/v1/endpoints/quality", "tag": "quality" },
      { "pattern": "backend/app/api/v1/endpoints/equipment", "tag": "equipment" },
      { "pattern": "backend/app/api/v1/endpoints/maintenance", "tag": "equipment" },
      { "pattern": "backend/app/api/v1/endpoints/(message|notification|websocket)", "tag": "message" },
      { "pattern": "backend/app/schemas/(user|role|permission|authz)", "tag": "authz" },
      { "pattern": "backend/app/schemas/production", "tag": "production" },
      { "pattern": "backend/app/schemas/product", "tag": "product" },
      { "pattern": "backend/app/schemas/process", "tag": "craft" },
      { "pattern": "backend/app/schemas/craft", "tag": "craft" },
      { "pattern": "backend/app/schemas/production", "tag": "production" },
      { "pattern": "backend/app/schemas/quality", "tag": "quality" },
      { "pattern": "backend/app/schemas/equipment", "tag": "equipment" },
      { "pattern": "backend/app/schemas/maintenance", "tag": "equipment" },
      { "pattern": "backend/app/schemas/(message|notification|websocket)", "tag": "message" },
      { "pattern": "backend/app/schemas/", "tag": "backend-core" },
      { "pattern": "backend/app/core/", "tag": "backend-core" },
      { "pattern": "backend/app/db/", "tag": "backend-core" },
      { "pattern": "backend/app/bootstrap/", "tag": "backend-core" },
      { "pattern": "backend/app/main.py", "tag": "backend-core" },
      { "pattern": "backend/app/worker_main.py", "tag": "backend-core" },
      { "pattern": "frontend/lib/core/", "tag": "frontend-core" },
      { "pattern": "frontend/lib/main.dart", "tag": "frontend-core" },
      { "pattern": "frontend/lib/features/(user|login|role|permission|authz)", "tag": "authz" },
      { "pattern": "frontend/lib/features/production", "tag": "production" },
      { "pattern": "frontend/lib/features/product", "tag": "product" },
      { "pattern": "frontend/lib/features/process", "tag": "craft" },
      { "pattern": "frontend/lib/features/craft", "tag": "craft" },
      { "pattern": "frontend/lib/features/production", "tag": "production" },
      { "pattern": "frontend/lib/features/quality", "tag": "quality" },
      { "pattern": "frontend/lib/features/equipment", "tag": "equipment" },
      { "pattern": "frontend/lib/features/maintenance", "tag": "equipment" },
